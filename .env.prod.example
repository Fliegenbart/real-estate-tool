# Vorlage fuer die .env neben docker-compose.prod.yml auf dem Server.
POSTGRES_DB=realestate
POSTGRES_USER=realestate
POSTGRES_PASSWORD=
# Zugriffsschutz der API; gleicher Wert kommt als NEXT_PUBLIC_API_KEY zu Vercel.
API_KEY=
# Oeffentlicher Port des Backends (Vercel-Rewrite zeigt hierauf)
BACKEND_PORT=8201
CORS_ORIGINS=https://real-estate-tool-pi.vercel.app
# Mail-Poller
IMAP_HOST=imap.gmail.com
IMAP_USER=
IMAP_PASSWORD=
IMAP_SINCE_DAYS=30
