# Backend
DATABASE_URL=postgresql+psycopg://realestate:realestate@localhost:5432/realestate

# Docker Compose database
POSTGRES_DB=realestate
POSTGRES_USER=realestate
POSTGRES_PASSWORD=realestate

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# E-Mail-Poller (gehoert in backend/.env) - liest Suchagenten-Mails aus einem
# Gmail-Label und importiert sie automatisch ins Tool. IMAP_PASSWORD ist ein
# Google App-Passwort (myaccount.google.com/apppasswords, erfordert 2FA).
IMAP_HOST=imap.gmail.com
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=immo-agent
API_BASE_URL=http://localhost:8000/api
